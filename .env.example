# Copy this file to .env before local Docker testing.

# Local image names.
IMAGE_NAMESPACE=tracegrid
IMAGE_TAG=local

# Local browser-facing frontend config.
# Empty values make the frontend call the same origin and let Next/Nginx proxy to backend.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_BASE_URL=
NEXT_PUBLIC_API_TIMEOUT_MS=6500
NEXT_PUBLIC_REPOSITORY_API_TIMEOUT_MS=45000
NEXT_PUBLIC_TRACEGRID_VERSION=hackathon
NEXT_PUBLIC_GIT_SHA=local
NEXT_PUBLIC_BUILD_TIME=dev-build
INTERNAL_API_BASE_URL=http://backend:8000

# Backend config.
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_TIMEOUT_SECONDS=2.8
TRACEGRID_LIVE_AGENT=none
ALLOW_GITHUB_INGESTION=true
GITHUB_CLONE_TIMEOUT_SECONDS=25
SPEECHMATICS_API_KEY=
SPEECHMATICS_MP_URL=https://mp.speechmatics.com
SPEECHMATICS_JWT_TTL_SECONDS=60
SPEECHMATICS_RT_URL=wss://eu2.rt.speechmatics.com/v2
SPEECHMATICS_AUTH_QUERY=jwt
SPEECHMATICS_LANGUAGE=en
SPEECHMATICS_OPERATING_POINT=enhanced
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional services kept internal by default.
NEO4J_AUTH=neo4j/password
NEO4J_URI=bolt://neo4j:7687
REDIS_URL=redis://redis:6379/0
