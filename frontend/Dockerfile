FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci --no-audit --no-fund

COPY . .

ENV NEXT_TELEMETRY_DISABLED=1
ARG NEXT_PUBLIC_API_BASE_URL=
ARG NEXT_PUBLIC_WS_BASE_URL=
ARG NEXT_PUBLIC_API_TIMEOUT_MS=6500
ARG NEXT_PUBLIC_REPOSITORY_API_TIMEOUT_MS=45000
ARG NEXT_PUBLIC_TRACEGRID_VERSION=hackathon
ARG NEXT_PUBLIC_GIT_SHA=local
ARG NEXT_PUBLIC_BUILD_TIME=dev-build
ARG INTERNAL_API_BASE_URL=http://backend:8000
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NEXT_PUBLIC_WS_BASE_URL=${NEXT_PUBLIC_WS_BASE_URL}
ENV NEXT_PUBLIC_API_TIMEOUT_MS=${NEXT_PUBLIC_API_TIMEOUT_MS}
ENV NEXT_PUBLIC_REPOSITORY_API_TIMEOUT_MS=${NEXT_PUBLIC_REPOSITORY_API_TIMEOUT_MS}
ENV NEXT_PUBLIC_TRACEGRID_VERSION=${NEXT_PUBLIC_TRACEGRID_VERSION}
ENV NEXT_PUBLIC_GIT_SHA=${NEXT_PUBLIC_GIT_SHA}
ENV NEXT_PUBLIC_BUILD_TIME=${NEXT_PUBLIC_BUILD_TIME}
ENV INTERNAL_API_BASE_URL=${INTERNAL_API_BASE_URL}

RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]
